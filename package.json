{
  "name": "advance-wars-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A browser field console for an owner-supplied Advance Wars 2 cartridge image.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "npm test && npm run build && npm run test:build",
    "test": "node --test test/*.test.mjs",
    "test:build": "node scripts/verify-build.mjs",
    "test:e2e": "playwright test e2e/game.spec.mjs",
    "test:e2e:live": "playwright test e2e/production.smoke.spec.mjs",
    "preview": "node scripts/serve.mjs"
  },
  "dependencies": {
    "@emulatorjs/core-mgba": "4.2.3",
    "@emulatorjs/emulatorjs": "4.2.3",
    "@fontsource/bebas-neue": "5.2.7",
    "@fontsource/ibm-plex-mono": "5.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  },
  "overrides": {
    "@emulatorjs/emulatorjs": "4.2.3",
    "glob": "10.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
